<?xml version="1.0" encoding="UTF-8"?>
<Configuration packages="com.automation" status="info">

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%-5p] [%c{1}] - %msg%n"/>
        </Console>

        <!-- File Appender -->
        <File name="File" fileName="logs/automation.log" append="false">
            <PatternLayout pattern="[%d{yyyy-MM-dd HH:mm:ss}] [%-5p] [%c{1}] - %msg%n"/>
        </File>

        <!-- RollingFile Appender -->
        <RollingFile name="RollingFile" fileName="logs/automation.log"
                     filePattern="logs/automation-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="[%d{yyyy-MM-dd HH:mm:ss}] [%-5p] [%c{1}] - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Root Logger -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
            <AppenderRef ref="RollingFile"/>
        </Root>

        <!-- Package specific loggers -->
        <Logger name="utils" level="debug"/>
        <Logger name="pages" level="debug"/>
        <Logger name="tests" level="info"/>
    </Loggers>

</Configuration>
